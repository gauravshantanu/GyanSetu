# ─────────────────────────────────────────────
#  GyanSetu — Environment Variables
#  Copy this file to .env.local and fill values
# ─────────────────────────────────────────────

# Supabase (free tier — supabase.com)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Groq AI (free tier, no billing needed — console.groq.com)
GROQ_API_KEY=your_groq_api_key

# YouTube Data API v3 (free — console.cloud.google.com)
NEXT_PUBLIC_YOUTUBE_API_KEY=your_youtube_api_key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
